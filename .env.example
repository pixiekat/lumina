# ── ctomop ───────────────────────────────────────────────────────────────────
CTOMOP_POSTGRES_USER=<your-ctomop-db-user>
CTOMOP_POSTGRES_PASSWORD=<your-ctomop-db-password>
CTOMOP_POSTGRES_DB=<your-ctomop-db-name>
CTOMOP_SECRET_KEY=<your-ctomop-secret-key>
CTOMOP_DEBUG=True
CTOMOP_PRODUCTION_URL=http://localhost:8000
CTOMOP_SUB_PATH=

# ── exact ────────────────────────────────────────────────────────────────────
EXACT_POSTGRES_USER=<your-exact-db-user>
EXACT_POSTGRES_PASSWORD=<your-exact-db-password>
EXACT_POSTGRES_DB=<your-exact-db-name>
EXACT_SECRET_KEY=<your-exact-secret-key>
EXACT_DEBUG=true
EXACT_ALLOWED_HOSTS=localhost,127.0.0.1

# ── shared ───────────────────────────────────────────────────────────────────
ENVIRONMENT=local